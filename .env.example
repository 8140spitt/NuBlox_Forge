# NuBlox Forge runtime persistence
# v0.6 keeps the server on the in-memory adapter while the MySQL adapter contract is hardened.
NUBLOX_PERSISTENCE_ADAPTER=memory

# Future v0.7 concrete MySQL edge adapter settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=nublox_forge
MYSQL_USER=root
MYSQL_PASSWORD=
