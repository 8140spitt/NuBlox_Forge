# NuBlox Forge runtime persistence
# Use memory for local UI work without a database.
# Use mysql when /api/snapshots should persist into the database.
NUBLOX_PERSISTENCE_ADAPTER=memory

# Concrete MySQL edge adapter settings for NUBLOX_PERSISTENCE_ADAPTER=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=nublox_forge
MYSQL_USER=nublox_user
MYSQL_PASSWORD=change_me
MYSQL_CONNECTION_LIMIT=10
