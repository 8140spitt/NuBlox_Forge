{
  "name": "@nublox/mysql-adapter",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mysql2-executor": {
      "types": "./src/mysql2-executor.ts",
      "import": "./src/mysql2-executor.ts",
      "default": "./src/mysql2-executor.ts"
    }
  },
  "dependencies": {
    "@nublox/schema-engine": "workspace:*",
    "@nublox/record-engine": "workspace:*",
    "@nublox/audit-engine": "workspace:*",
    "@nublox/persistence-engine": "workspace:*",
    "mysql2": "latest"
  }
}
